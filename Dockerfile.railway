FROM nousresearch/hermes-agent:latest

ENV HERMES_DASHBOARD=true \
    HERMES_DASHBOARD_HOST=0.0.0.0 \
    HERMES_DASHBOARD_PORT=9119 \
    HERMES_GATEWAY_BOOTSTRAP_STATE=running \
    PORT=9119

EXPOSE 9119

# Keep the base image's /init entrypoint running so s6 can supervise the
# dashboard service. Railway start-command overrides replace ENTRYPOINT, so the
# long-lived command belongs in CMD instead.
CMD ["sleep", "infinity"]
